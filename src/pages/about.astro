---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About - Steve Kim"
  description="Learn more about [Your Name], their background, skills, and experience."
>
  <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
    <!-- Page Header -->
    <div class="mb-12 text-center">
      <h1 class="mb-4 text-4xl font-bold text-gray-900 dark:text-gray-100">
        About Me
      </h1>
      <p class="text-lg text-gray-600 dark:text-gray-400">
        Get to know me a little better
      </p>
    </div>

    <!-- Profile Section -->
    <section class="mb-16">
      <div class="flex flex-col items-center gap-8 md:flex-row md:items-start">
        <!-- Profile Image Placeholder -->
        <div class="h-48 w-48 flex-shrink-0 rounded-full bg-gradient-to-br from-blue-400 to-purple-600"></div>

        <!-- Bio -->
        <div class="flex-1">
          <h2 class="mb-4 text-2xl font-semibold text-gray-900 dark:text-gray-100">
            Hello! I'm Your Name
          </h2>
          <div class="space-y-4 text-gray-700 dark:text-gray-300">
            <p>
              I'm a passionate software developer with a love for creating elegant and efficient
              solutions to complex problems. My journey in technology started [when you started],
              and I've been hooked ever since.
            </p>
            <p>
              When I'm not coding, you can find me [your hobbies/interests]. I believe in
              continuous learning and am always exploring new technologies and methodologies to
              improve my craft.
            </p>
            <p>
              I'm particularly interested in [your specific interests/areas of focus], and I'm
              always excited to collaborate on projects that make a positive impact.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Skills Section -->
    <section class="mb-16">
      <h2 class="mb-6 text-2xl font-semibold text-gray-900 dark:text-gray-100">
        Skills & Technologies
      </h2>
      <div class="grid gap-6 md:grid-cols-2">
        <div class="rounded-lg border border-gray-200 bg-white p-6 dark:border-gray-800 dark:bg-gray-800">
          <h3 class="mb-3 text-lg font-semibold text-gray-900 dark:text-gray-100">
            Frontend
          </h3>
          <div class="flex flex-wrap gap-2">
            <span class="rounded-full bg-blue-100 px-3 py-1 text-sm font-medium text-blue-800 dark:bg-blue-900 dark:text-blue-200">
              JavaScript
            </span>
            <span class="rounded-full bg-blue-100 px-3 py-1 text-sm font-medium text-blue-800 dark:bg-blue-900 dark:text-blue-200">
              TypeScript
            </span>
            <span class="rounded-full bg-blue-100 px-3 py-1 text-sm font-medium text-blue-800 dark:bg-blue-900 dark:text-blue-200">
              React
            </span>
            <span class="rounded-full bg-blue-100 px-3 py-1 text-sm font-medium text-blue-800 dark:bg-blue-900 dark:text-blue-200">
              Astro
            </span>
            <span class="rounded-full bg-blue-100 px-3 py-1 text-sm font-medium text-blue-800 dark:bg-blue-900 dark:text-blue-200">
              Tailwind CSS
            </span>
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-6 dark:border-gray-800 dark:bg-gray-800">
          <h3 class="mb-3 text-lg font-semibold text-gray-900 dark:text-gray-100">
            Backend & Tools
          </h3>
          <div class="flex flex-wrap gap-2">
            <span class="rounded-full bg-green-100 px-3 py-1 text-sm font-medium text-green-800 dark:bg-green-900 dark:text-green-200">
              Node.js
            </span>
            <span class="rounded-full bg-green-100 px-3 py-1 text-sm font-medium text-green-800 dark:bg-green-900 dark:text-green-200">
              Python
            </span>
            <span class="rounded-full bg-green-100 px-3 py-1 text-sm font-medium text-green-800 dark:bg-green-900 dark:text-green-200">
              Git
            </span>
            <span class="rounded-full bg-green-100 px-3 py-1 text-sm font-medium text-green-800 dark:bg-green-900 dark:text-green-200">
              Docker
            </span>
            <span class="rounded-full bg-green-100 px-3 py-1 text-sm font-medium text-green-800 dark:bg-green-900 dark:text-green-200">
              SQL
            </span>
          </div>
        </div>
      </div>
    </section>

    <!-- Experience Section -->
    <section class="mb-16">
      <h2 class="mb-6 text-2xl font-semibold text-gray-900 dark:text-gray-100">
        Experience
      </h2>
      <div class="space-y-6">
        <div class="border-l-4 border-blue-600 pl-4 dark:border-blue-400">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100">
            Your Current Position
          </h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Company Name | Start Date - Present
          </p>
          <p class="mt-2 text-gray-700 dark:text-gray-300">
            Brief description of your role, responsibilities, and key achievements.
          </p>
        </div>

        <div class="border-l-4 border-gray-300 pl-4 dark:border-gray-700">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100">
            Previous Position
          </h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Company Name | Start Date - End Date
          </p>
          <p class="mt-2 text-gray-700 dark:text-gray-300">
            Brief description of your role, responsibilities, and key achievements.
          </p>
        </div>
      </div>
    </section>

    <!-- Contact CTA -->
    <section class="rounded-lg border border-gray-200 bg-gradient-to-r from-blue-50 to-purple-50 p-8 text-center dark:border-gray-800 dark:from-blue-950 dark:to-purple-950">
      <h2 class="mb-4 text-2xl font-semibold text-gray-900 dark:text-gray-100">
        Let's Connect
      </h2>
      <p class="mb-6 text-gray-700 dark:text-gray-300">
        I'm always interested in hearing about new projects and opportunities.
      </p>
      <a
        href="mailto:your.email@example.com"
        class="inline-block rounded-lg bg-blue-600 px-8 py-3 font-medium text-white transition-colors hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600"
      >
        Get in Touch
      </a>
    </section>
  </div>
</BaseLayout>
